+# mobile-forge: preload the bundled Arrow C++ runtime so dyld can resolve the
+# extension modules' @rpath link to libarrow after flet relocates each .so into
+# its own framework on iOS. No-op where the dylibs aren't bundled here.
+try:
+    import ctypes as _ctypes
+    _pyarrow_dir = _os.path.dirname(_os.path.abspath(__file__))
+    for _arrow_lib in ("libarrow.2400.dylib",
+                       "libarrow_compute.2400.dylib",
+                       "libarrow_python.2400.dylib"):
+        for _cand in (
+            _os.path.join(_pyarrow_dir, _arrow_lib),
+            _os.path.join(_pyarrow_dir, _arrow_lib[:-len(".dylib")] + ".0.0.dylib"),
+            _os.path.join(_pyarrow_dir, _arrow_lib[:-len(".dylib")] + ".fwork"),
+        ):
+            if _os.path.exists(_cand):
+                try:
+                    _ctypes.CDLL(_cand, mode=_ctypes.RTLD_GLOBAL)
+                except OSError:
+                    pass
+                break
+except Exception:
+    pass
+
