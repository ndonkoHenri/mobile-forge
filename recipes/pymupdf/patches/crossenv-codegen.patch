+    #      headers), else MuPDF structs parse incompletely.
+    #  (3) __main__.py: the cross build dir is '<arch>-...-shared-...', so
+    #      `startswith('shared-')` is False and libmupdf is dropped from the
+    #      _mupdf.so link -> undefined fz_* symbols. Match 'shared-' anywhere.
+    if mupdf_local and os.path.isdir('/System/Library/Frameworks'):
+        try:
+            _mf_state = os.path.join(mupdf_local, 'scripts', 'wrap', 'state.py')
